{
  "name": "kangaroo-mobile",
  "version": "0.0.1",
  "description": "A Vue 3 mobile framework inspired by Umi",
  "type": "module",
  "main": "dist/kangaroo-mobile.cjs.js",
  "module": "dist/kangaroo-mobile.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/kangaroo-mobile.js"
    },
    "./style.css": {
      "development": "./src/theme/index.less",
      "default": "./dist/kangaroo-mobile.css"
    }
  },
  "files": [
    "dist",
    "src/theme",
    "src/assets/icons"
  ],
  "scripts": {
    "dev:play": "vite --host --config playground/vite.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "publish:public": "npm run build && npm publish --access public"
  },
  "keywords": [
    "vue",
    "mobile",
    "framework",
    "vite-plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@vant/area-data": "^2.1.0",
    "vant": "^4.10.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "less": "^4.6.7",
    "svgo": "^4.0.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue": "^7.2.0",
    "vite": "^8.1.0",
    "vue-router": "^4.0.0",
    "pinia": "^3.0.0"
  }
}
