    "vite-plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "vant": "^4.10.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "less": "^4.6.7",
    "svgo": "^4.0.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue": "^7.2.0",
    "vite": "^8.1.0"
  }
}
