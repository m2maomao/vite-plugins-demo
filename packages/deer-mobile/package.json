{
  "name": "deer-mobile",
  "version": "0.1.31",
  "type": "module",
  "main": "./index.js",
  "scripts": {
    "build": "npx esbuild index.ts --bundle --outfile=index.js --format=esm --platform=node --external:fast-glob --external:esbuild --external:virtual:* --external:deer-mobile --external:deer-mobile/* --charset=utf8",
    "publish:dev": "pnpm build && npm version patch && npm publish --registry http://localhost:4873"
  },
  "exports": {
    ".": {
      "development": "./index.ts",
      "default": "./index.js"
    },
    "./composables": {
      "development": "./src/composables/useApi.ts",
      "default": "./src/composables/useApi.ts"
    },
    "./utils": {
      "development": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./layouts": {
      "development": "./src/layouts/index.tsx",
      "default": "./src/layouts/index.tsx"
    },
    "./stores": {
      "development": "./src/stores/index.ts",
      "default": "./src/stores/index.ts"
    },
    "./style.css": {
      "development": "./src/style.css",
      "default": "./src/style.css"
    },
    "./runtime": {
      "development": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    },
    "./runtime/pinia": {
      "development": "./plugins/runtime/pinia-plugin.ts",
      "default": "./plugins/runtime/pinia-plugin.ts"
    },
    "./runtime/auth": {
      "development": "./plugins/runtime/auth-plugin.ts",
      "default": "./plugins/runtime/auth-plugin.ts"
    },
    "./runtime/i18n": {
      "development": "./plugins/runtime/i18n-plugin.ts",
      "default": "./plugins/runtime/i18n-plugin.ts"
    },
    "./runtime/api": {
      "development": "./plugins/runtime/api-plugin.ts",
      "default": "./plugins/runtime/api-plugin.ts"
    },
    "./runtime/layout": {
      "development": "./plugins/runtime/layout-plugin.ts",
      "default": "./plugins/runtime/layout-plugin.ts"
    },
    "./build": {
      "development": "./src/build/index.ts",
      "default": "./src/build/index.ts"
    }
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "kangaroo-mobile": "workspace:*",
    "vue-i18n": "^11.0.0",
    "sm-crypto": "^0.4.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0",
    "axios": "^1.0.0",
    "@vueuse/core": "^14.0.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.0.0",
    "vite": "^8.0.0",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "esbuild": "^0.28.0"
  },
  "peerDependenciesMeta": {}
}
