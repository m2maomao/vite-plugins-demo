{
  "name": "deer-mobile",
  "version": "0.1.31",
  "type": "module",
  "main": "./index.js",
  "scripts": {
    "build": "npx esbuild index.ts --bundle --outfile=index.js --format=esm --platform=node --external:fast-glob --external:esbuild --charset=utf8",
    "publish:dev": "pnpm build && npm version patch && npm publish --registry http://localhost:4873"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./index.js"
    },
    "./composables": {
      "development": "./src/composables/useApi.ts",
      "default": "./dist/composables/useApi.js"
    },
    "./utils": {
      "development": "./src/utils/index.ts",
      "default": "./dist/utils/index.js"
    },
    "./layouts": {
      "development": "./src/layouts/index.tsx",
      "default": "./dist/layouts/index.js"
    },
    "./stores": {
      "development": "./src/stores/index.ts",
      "default": "./dist/stores/index.js"
    },
    "./style.css": {
      "development": "./src/style.css",
      "default": "./dist/style.css"
    }
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "kangaroo-mobile": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0",
    "axios": "^1.0.0",
    "@vueuse/core": "^14.0.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.0.0",
    "vite": "^8.0.0",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "esbuild": "^0.28.0",
    "sm-crypto": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "sm-crypto": {
      "optional": true
    }
  }
}
