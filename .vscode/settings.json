{
  // 默认使用 LF 换行符
  "files.eol": "\n",
  // 保存时自动格式化
  "editor.formatOnSave": true,
  // 默认的格式化工具设为 Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // 对特定语言启用不同的格式化器
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ESLint 配置
  "eslint.validate": ["javascript", "typescript", "typescriptreact", "vue"],
  // 保存时自动修复 ESLint 问题
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  }
}
