{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client", "vue/jsx"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    // JSX
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment"
  },
  "include": [
    "apps/example/src",
    "apps/example/plugins",
    "apps/example/server",
    "packages/deer-mobile/src",
    "packages/deer-mobile/plugins",
    "packages/kangaroo-mobile/src"
  ]
}
